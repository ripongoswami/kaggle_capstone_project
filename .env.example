# Database Configuration
DATABASE_URL=sqlite:///./eduverse.db

# Security & JWT Configuration
JWT_SECRET=super_secret_jwt_sign_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=600

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API
TAVILY_API_KEY=your_tavily_api_key_here

# Set to false to use real Gemini API calls (requires valid GEMINI_API_KEY)
# When true (default), agents return demo data so the app works without API keys
USE_MOCK_AGENTS=true

# Host / Port Settings
BACKEND_PORT=8000
FRONTEND_PORT=3000
